.doc-next{ right:-10px; }

/* Modal Zoom */
.doc-modal{
  display:none;
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.9);
  justify-content:center;
  align-items:center;
  z-index:9999;
}

.doc-modal img{
  max-width:90%;
  max-height:90%;
  background:#fff;
  padding:15px;
  border-radius:10px;
}

.doc-close{
  position:absolute;
  top:20px;
  right:30px;
  font-size:40px;
  color:#fff;
  cursor:pointer;
}

