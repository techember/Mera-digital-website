<script>
let currentSlide = 0;
const slides = document.querySelectorAll(".slide");
const dots = document.querySelectorAll(".slider-nav .dot");

function showSlide(index){
  slides.forEach((s,i)=>{
    s.classList.remove("active");
    dots[i].classList.remove("active");
  });
  slides[index].classList.add("active");
  dots[index].classList.add("active");
}

function changeSlide(step){
  currentSlide = (currentSlide + step + slides.length) % slides.length;
  showSlide(currentSlide);
}

function goSlide(index){
  currentSlide = index;
  showSlide(currentSlide);
}

// Auto slide
setInterval(()=>changeSlide(1), 5000);
</script>
<script>
let index = 0;
const track = document.querySelector('.testimonial-track');
const cards = document.querySelectorAll('.testimonial-card');

function slideTestimonial(step){
  const visible = window.innerWidth < 768 ? 1 : 3;
  index = (index + step + cards.length) % cards.length;
  track.style.transform = `translateX(-${index * (100/visible)}%)`;
}

document.querySelector('.ts-next').onclick = ()=>slideTestimonial(1);
document.querySelector('.ts-prev').onclick = ()=>slideTestimonial(-1);

// Auto slide
setInterval(()=>slideTestimonial(1), 4000);
</script>
<script>
let docIndex = 0;
const docTrack = document.querySelector('.doc-track');
const docItems = document.querySelectorAll('.doc-item');

function moveDoc(step){
  const visible = window.innerWidth < 768 ? 1 : 3;
  docIndex = (docIndex + step + docItems.length) % docItems.length;
  docTrack.style.transform = `translateX(-${docIndex * (100/visible)}%)`;
}

document.querySelector('.doc-next').onclick = ()=>moveDoc(1);
document.querySelector('.doc-prev').onclick = ()=>moveDoc(-1);

// Auto slide
setInterval(()=>moveDoc(1), 4000);

// Zoom
function openDoc(img){
  document.getElementById("docModal").style.display="flex";
  document.getElementById("docModalImg").src = img.src;
}
function closeDoc(){
  document.getElementById("docModal").style.display="none";
}
</script>
<script>
function scrollStaff(direction){
  const container = document.getElementById("staffScroll");
  const card = container.querySelector(".staff-card");
  const gap = 25; // same as CSS gap

  const scrollAmount = card.offsetWidth + gap;

  container.scrollBy({
    left: direction * scrollAmount,
    behavior: "smooth"
  });
}
</script>
<script>
window.addEventListener("load", () => {
  document.querySelectorAll(".fill").forEach(bar => {
    const percent = bar.getAttribute("data-percent");
    bar.style.width = percent + "%";
  });
});
</script>

