  <div class="container">
    <h1>Income Calculator</h1>
    <p>Estimate your daily & monthly earnings with Mera Digital APS</p>
  </div>
</section>

<!-- ================= CALCULATOR ================= -->
<section class="income-wrap">
  <div class="container income-grid">

    <!-- LEFT : SERVICES -->
