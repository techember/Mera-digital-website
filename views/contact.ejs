<%- include('includes/header') %>

<!-- ===== CONTACT HERO ===== -->
<section class="service-hero">
  <div class="container">
    <h1>Contact Us</h1>
    <p>We are here to help you. Get in touch with Mera Digital APS</p>
  </div>
</section>

<!-- ===== CONTACT CONTENT ===== -->
<section class="service-content">
  <div class="container service-grid">

    <!-- LEFT : CONTACT INFO -->
    <div class="service-text">
      <h2>Get in Touch</h2>
      <p>
        Have questions or need support? Reach out to us through the contact
        details below or send us a message.
      </p>

      <ul class="service-points">
        <li>
          <i class="fa-solid fa-location-dot"></i>
          Ground Floor, Office No. 82, Bari Kheda, Aonla, Bareilly, UP – 243301
        </li>
        <li>
          <i class="fa-solid fa-phone"></i>
          +91 70888 98725
        </li>
        <li>
          <i class="fa-solid fa-envelope"></i>
          help.meradigitalaps@gmail.com
        </li>
      </ul>
    </div>

    <!-- RIGHT : CONTACT FORM -->
    <div class="service-image">
      <form class="contact-form">
        <h3>Send Message</h3>

        <input type="text" placeholder="Your Name" required>
        <input type="email" placeholder="Your Email" required>
        <input type="text" placeholder="Your Mobile" required>
        <textarea placeholder="Your Message" rows="4"></textarea>

        <button type="submit" class="btn-primary">
          <i class="fa-solid fa-paper-plane"></i> Submit
        </button>
      </form>
    </div>

  </div>
</section>

<%- include('includes/footer') %>
